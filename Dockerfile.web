FROM node:22-alpine AS build
WORKDIR /app
RUN corepack enable
ENV PNPM_FETCH_RETRIES=8 PNPM_FETCH_RETRY_MINTIMEOUT=10000 PNPM_FETCH_RETRY_MAXTIMEOUT=120000 PNPM_NETWORK_CONCURRENCY=4
COPY . .
RUN pnpm install --frozen-lockfile && pnpm --filter @ocean/web build

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public
EXPOSE 3000
USER node
CMD ["node", "apps/web/server.js"]
